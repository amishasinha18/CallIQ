PORT=4100
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:4200

# Postgres (Supabase project settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Supabase Storage (Project settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Bucket names — only needed if you name the buckets something other than these defaults
# SUPABASE_RECORDINGS_BUCKET=recordings
# SUPABASE_PRODUCT_IMAGES_BUCKET=product-images

# Redis (Upstash dashboard → REST/TCP connection, use the rediss:// TLS URL)
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# LiveKit Cloud (project dashboard → Settings → Keys)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_HTTP_URL=https://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
